 "_readme": {
  "title": "LTX-2.3 22B IC-LoRA Ingredients \u2014 SEAMLESS LONG VIDEO via LTXVExtendSampler chain (video-only, no audio)",
  "verified": "2026-07-07: 361f (15.04s) 928x576 in 216s, motion-continuous, no sheet-copy at any phase",
  "structure": "official distilled base gen (121f, nodes <9000) -> 9006 ExtendSampler +120f (beat2 prompt via 9002-9005) -> 9016 ExtendSampler +120f (beat3 via 9012-9015) -> 9020 decode once -> 9022 SaveVideo",
  "patch_points": {
   "2004.inputs.image": "reference sheet (pre-resized, shorter side = latent height)",
   "2483.inputs.text": "beat1 prompt (base gen)",
   "9002/9012.inputs.text": "beat2/beat3 prompts",
   "4832/9005/9015.inputs.noise_seed": "seeds",
   "5072.inputs.value": "base frames (121)",
   "9006/9016.inputs.num_new_frames": "extension sizes (multiples of 8)"
  },
  "gotchas": [
   "extension sampler MUST be plain euler_ancestral (node 9001) \u2014 euler_ancestral_cfg_pp crashes with STGGuiderAdvanced (uncond_denoised None)",
   "STGGuiderAdvanced list params (cfg_values etc) must match sigmas count; all-1/all-0 mimics distilled CFG-1",
   "video-only path: no audio latent \u2014 mux audio afterwards (T2A or external)",
   "add more ExtendSampler stages for longer videos; each +120f \u2248 +60-70s gen"
  ]
 }
